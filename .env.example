# Copy this file to .env and fill in your keys. Neither file is committed to git.
# All three keys below can also be entered directly in-app via Customize > Data & API keys,
# with no rebuild or restart needed — this file is only for a dev/CI-style setup.

# Free tier at https://finnhub.io — powers live quotes, candles, and ticker-filtered news.
VITE_FINNHUB_API_KEY=

# Optional, free tier at https://twelvedata.com — broader bond/ETF coverage as a Finnhub supplement.
VITE_TWELVE_DATA_API_KEY=

# Without either key set, the app runs entirely on realistic generated mock data.

# Fallback for "Get AI insights" in the Portfolio panel — only used if the Claude Code
# CLI isn't installed/signed in on this computer. NOT prefixed with VITE_: this is read
# only in the Electron main process (src/main/aiInsights.ts) and is never bundled into
# the renderer, so it's never reachable from devtools or client-side code.
ANTHROPIC_API_KEY=
