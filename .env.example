# Copy this file to .env and fill in your keys. Neither file is committed to git.
# All keys below can also be entered directly in-app via Customize > Data & API keys,
# with no rebuild or restart needed — this file is only for a dev/CI-style setup.

# Free tier at https://finnhub.io/register — powers live quotes, company profiles, and
# ticker-filtered news. Historical candles are confirmed paid-tier-only on Finnhub's free plan.
VITE_FINNHUB_API_KEY=

# Free tier at https://twelvedata.com/register — real multi-year daily history for stocks, bonds,
# FX, and crypto. The main upgrade path for real historical charts in this app (Phase 8.8).
VITE_TWELVE_DATA_API_KEY=

# Optional, free Demo plan at https://www.coingecko.com/en/api/pricing — real crypto price
# history. Works keyless too (this key just raises the rate limit); full daily-or-finer
# resolution within the last 30 days, coarser beyond that on the free tier.
VITE_COINGECKO_API_KEY=

# Without any keys set, the app runs entirely on realistic generated mock data.

# Fallback for "Get AI insights" in the Portfolio panel — only used if the Claude Code
# CLI isn't installed/signed in on this computer. NOT prefixed with VITE_: this is read
# only in the Electron main process (src/main/aiInsights.ts) and is never bundled into
# the renderer, so it's never reachable from devtools or client-side code.
ANTHROPIC_API_KEY=
